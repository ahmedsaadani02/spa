{
  "name": "spa-invoice-web",
  "version": "1.0.0",
  "private": true,
  "description": "SPA Societe d'Aluminium - application web de gestion",
  "scripts": {
    "start": "npm run web:serve",
    "backend:install": "npm install --prefix backend",
    "backend:start": "npm run start --prefix backend",
    "backend:db:pg:test": "npm run db:pg:test --prefix backend",
    "backend:db:pg:schema:apply": "npm run db:pg:schema:apply --prefix backend",
    "frontend:start": "npm run start --prefix frontend",
    "frontend:build": "npm run build --prefix frontend",
    "frontend:typecheck": "npm run typecheck --prefix frontend",
    "web:setup": "npm run backend:install",
    "web:serve": "concurrently -k \"npm run backend:start\" \"npm run frontend:start\"",
    "db:pg:test": "npm run backend:db:pg:test",
    "db:pg:schema:apply": "npm run backend:db:pg:schema:apply",
    "db:pg:tranche1:audit": "node database/scripts/audit-postgres-tranche1.js",
    "db:pg:tranche2:audit": "node database/scripts/audit-postgres-tranche2-auth-session.js",
    "db:pg:tranche3:audit": "node database/scripts/audit-postgres-tranche3-catalog-read.js",
    "db:pg:quotes-read:audit": "node database/scripts/audit-postgres-quotes-read.js",
    "db:pg:quotes-write:audit": "node database/scripts/audit-postgres-quotes-write.js",
    "db:pg:quotes-convert:audit": "node database/scripts/audit-postgres-quotes-convert.js",
    "db:pg:quotes-invoices-domain:audit": "node database/scripts/audit-postgres-quotes-invoices-domain.js",
    "db:pg:backend-global:audit": "node database/scripts/audit-postgres-backend-global.js",
    "db:pg:invoices-read:audit": "node database/scripts/audit-postgres-invoices-read.js",
    "db:pg:invoices-write:audit": "node database/scripts/audit-postgres-invoices-write.js",
    "db:pg:invoices-delete:audit": "node database/scripts/audit-postgres-invoices-delete.js",
    "db:pg:movements-read:audit": "node database/scripts/audit-postgres-movements-read.js",
    "db:pg:price-history-read:audit": "node database/scripts/audit-postgres-price-history-read.js",
    "db:pg:products-write:audit": "node database/scripts/audit-postgres-products-write.js",
    "db:pg:products-create-update:audit": "node database/scripts/audit-postgres-products-create-update.js",
    "db:pg:products-price-write:audit": "node database/scripts/audit-postgres-products-price-write.js",
    "db:pg:products-purge:audit": "node database/scripts/audit-postgres-products-purge.js",
    "db:pg:stock-setqty:audit": "node database/scripts/audit-postgres-stock-setqty.js",
    "db:pg:stock-delta:audit": "node database/scripts/audit-postgres-stock-delta.js",
    "db:pg:movements-write:audit": "node database/scripts/audit-postgres-movements-write.js",
    "db:pg:stock-apply-movement:audit": "node database/scripts/audit-postgres-stock-apply-movement.js",
    "db:pg:catalog-stock-domain:audit": "node database/scripts/audit-postgres-catalog-stock-domain.js",
    "db:sqlite:introspect": "node database/scripts/introspect-sqlite.js",
    "db:sqlite:audit": "node database/scripts/audit-sqlite-data.js",
    "db:migrate:sqlite-to-postgres": "node database/scripts/migrate-sqlite-to-postgres.js",
    "build": "npm run frontend:build",
    "typecheck": "npm run frontend:typecheck"
  },
  "dependencies": {
    "@angular/common": "21.2.4",
    "@angular/compiler": "21.2.4",
    "@angular/core": "21.2.4",
    "@angular/forms": "21.2.4",
    "@angular/platform-browser": "21.2.4",
    "@angular/router": "21.2.4",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "11.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "html2pdf.js": "^0.14.0",
    "resend": "^6.9.3",
    "rxjs": "^7.8.1",
    "tslib": "^2.6.3",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.2",
    "@angular/cli": "21.2.2",
    "@angular/compiler-cli": "21.2.4",
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.0",
    "typescript": "~5.9.0",
    "wait-on": "^7.2.0"
  },
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "overrides": {
    "ora": "5.4.1"
  }
}
