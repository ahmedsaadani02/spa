{
  "name": "spa-invoice-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "SPA Societe d'Aluminium - application desktop de facturation",
  "main": "electron/main.js",
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "electron:serve": "concurrently -k \"ng serve --port 4200\" \"wait-on http://localhost:4200 && electron .\"",
    "electron:build": "ng build --configuration production && electron-builder",
    "electron:pack": "ng build --configuration production && electron-builder --dir"
  },
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "rxjs": "^7.8.1",
    "tslib": "^2.6.3",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^19.2.19",
    "@angular/compiler-cli": "^21.0.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.7.0",
    "typescript": "~5.9.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.spa.invoice",
    "productName": "SPA Facturation",
    "files": [
      "dist/spa-invoice/**",
      "electron/**"
    ],
    "directories": {
      "buildResources": "build"
    },
    "asar": true
  },
  "overrides": {
  "ora": "5.4.1"
}
}
