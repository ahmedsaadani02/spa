+.form {
+  display: grid;
+  gap: 1rem;
+}
+
+.grid-2,
+.grid-4 {
+  display: grid;
+  gap: 1rem;
+}
+
+.grid-2 {
+  grid-template-columns: repeat(2, minmax(0, 1fr));
+}
+
+.grid-4 {
+  grid-template-columns: repeat(4, minmax(0, 1fr));
+}
+
+.textarea {
+  width: 100%;
+  min-height: 130px;
+  border-radius: 16px;
+  border: 1px solid rgba(15, 23, 42, 0.12);
+  padding: 0.85rem 1rem;
+  font: inherit;
+  color: #0f172a;
+  background: #fff;
+  resize: vertical;
+}
+
+.checkbox-field {
+  display: grid;
+  gap: 0.65rem;
+}
+
+.checkbox-inline {
+  display: inline-flex;
+  align-items: flex-start;
+  gap: 0.75rem;
+  color: #334155;
+}
+
+.checkbox-inline input {
+  margin-top: 0.15rem;
+}
+
+.task-meta-card {
+  padding: 14px 16px;
+  border-radius: 16px;
+  border: 1px solid rgba(15, 23, 42, 0.08);
+  background: #f8fafc;
+  color: #334155;
+  line-height: 1.6;
+}
+
+.subtasks-card {
+  display: grid;
+  gap: 1rem;
+  padding: 1rem;
+  border-radius: 20px;
+  border: 1px solid rgba(15, 23, 42, 0.08);
+  background: #f8fafc;
