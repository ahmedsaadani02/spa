+      <span class="loading-dot"></span>
+      <div>
+        <strong>{{ ui.admin.loadingStrong }}</strong>
+        <p>{{ ui.admin.loadingListText }}</p>
+      </div>
+    </div>
+    <div class="empty" *ngIf="!loading && tasks.length === 0">{{ ui.admin.noTask }}</div>
+
+    <div class="table" *ngIf="tasks.length > 0">
