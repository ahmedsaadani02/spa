+};
+
+const createTaskHistoryEntry = async (client, payload = {}) => {
+  await client.query(
+    `INSERT INTO task_update_history (
+       id,
+       task_id,
+       action_type,
+       comment,
+       status,
+       progress,
+       actor_id,
+       actor_name,
+       subtask_id,
+       subtask_title,
+       subtask_completed,
+       photo_count,
