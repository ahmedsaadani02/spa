+  height: 14px;
+  margin-top: 0.3rem;
+  border-radius: 999px;
+  background: linear-gradient(135deg, #1d4ed8, #38bdf8);
+  box-shadow: 0 0 0 6px rgba(59, 130, 246, 0.12);
+  animation: taskPulse 1.2s ease-in-out infinite;
+  flex-shrink: 0;
+}
+
+@keyframes taskPulse {
