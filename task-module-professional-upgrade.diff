+
+.subtasks-header p {
+  margin: 0.35rem 0 0;
+  color: #64748b;
+}
+
+.subtasks-list {
+  display: grid;
+  gap: 0.75rem;
+}
+
+.subtask-row {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) auto;
+  gap: 0.75rem;
+  align-items: center;
+}
+
+.loading-card {
+  min-height: 170px;
+  display: flex;
+  align-items: center;
+}
+
+.panel-header,
+.actions {
+  display: flex;
+  justify-content: space-between;
+  align-items: flex-start;
+  gap: 12px;
+}
+
+.loading-state {
+  display: flex;
+  align-items: flex-start;
+  gap: 0.9rem;
+  color: #334155;
+}
+
+.loading-state strong {
+  display: block;
+  font-size: 0.98rem;
+}
+
+.loading-state p {
+  margin: 0.35rem 0 0;
+  color: #64748b;
+}
+
+.loading-dot {
