# ─── Base de données ───────────────────────────────────────────────────────────

# Pilote actif : "sqlite" (local/dev) ou "postgres" (production)
DB_DRIVER=sqlite

# Chemin vers le fichier SQLite (optionnel — défaut : %APPDATA%/SPA/spa.db ou ./data/spa.db)
DATABASE_PATH=

# URL de connexion PostgreSQL (obligatoire si DB_DRIVER=postgres)
# Format : postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL=

# Configuration SSL Postgres : "auto" (détection), "true"/"1" (sans vérification cert), "false"/"0" (désactivé)
POSTGRES_SSL=auto

# ─── Opt-in PostgreSQL par domaine ─────────────────────────────────────────────
# Ces flags n'ont d'effet que si DB_DRIVER=postgres.
# Mettre à "1" pour activer Postgres sur le scope concerné, "0" pour rester sur SQLite.
# Règle : les writes nécessitent que les reads du même domaine soient aussi activés.

DB_ENABLE_POSTGRES_QUOTES_READ=0
DB_ENABLE_POSTGRES_QUOTES_WRITES=0
DB_ENABLE_POSTGRES_INVOICES_READ=0
DB_ENABLE_POSTGRES_INVOICES_WRITES=0
DB_ENABLE_POSTGRES_CATALOG_READ=0
DB_ENABLE_POSTGRES_PRODUCT_WRITES=0
DB_ENABLE_POSTGRES_STOCK_WRITES=0

# ─── Serveur ───────────────────────────────────────────────────────────────────

# Port d'écoute du backend (défaut : 3001)
PORT=3001

# Environnement Node : "development" ou "production"
NODE_ENV=development

# URL publique du backend (obligatoire en production).
# Utilisée pour construire les URLs des images produits et des preuves photo retournées par l'API.
# En production sur Render : https://<votre-app>.onrender.com
BACKEND_BASE_URL=

# Origines CORS autorisées (séparées par des virgules si plusieurs)
# Exemple production : https://pratique-aluminium.tn
CORS_ORIGIN=

# ─── Email (Resend) ────────────────────────────────────────────────────────────

RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=SPA Facturation

# ─── Pool de connexions PostgreSQL (optionnel) ─────────────────────────────────

# Nombre max de connexions dans le pool (défaut : 10)
PGPOOL_MAX=10

# Timeout d'inactivité d'une connexion en ms (défaut : 30000)
PG_IDLE_TIMEOUT_MS=30000

# Timeout d'établissement d'une connexion en ms (défaut : 10000)
PG_CONNECTION_TIMEOUT_MS=10000
